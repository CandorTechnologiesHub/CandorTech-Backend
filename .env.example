# Environment variable template for local development.
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# Never commit .env -- it is gitignored.
# This file (.env.example) IS committed and kept up to date.

# Database
DB_URL=jdbc:postgresql://localhost:5432/your_db_name
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters

# CORS (comma-separated list of allowed frontend origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email provider: javamail or sendgrid
MAIL_PROVIDER=javamail
SENDGRID_API_KEY=your-sendgrid-api-key

# SMTP / JavaMail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-smtp-password-or-app-password

# Frontend
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password
